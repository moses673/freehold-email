# ─────────────────────────────────────────────
# Freehold Email — Environment Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# ── REQUIRED ────────────────────────────────

# Your Postmark API key (get one at https://postmarkapp.com)
POSTMARK_API_KEY=your-postmark-server-api-token

# The email address you'll send from (must be verified in Postmark)
POSTMARK_FROM_EMAIL=you@yourdomain.com

# Your app's public URL (used in unsubscribe links and email footers)
APP_URL=https://yourdomain.com

# ── SECURITY (generate random strings) ──────

# Used to sign authentication tokens. Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# Used to sign unsubscribe links. Generate with: openssl rand -hex 32
UNSUBSCRIBE_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# ── OPTIONAL ────────────────────────────────

# Server port (default: 3001)
PORT=3001

# CORS origin (default: same as APP_URL)
CLIENT_URL=https://yourdomain.com

# Database file path (default: ./data/freehold.db)
# DB_PATH=/app/data/freehold.db

# Environment (default: production in Docker)
# NODE_ENV=production

# ── PAYMENTS (Stripe) ──────────────────────
# Required for processing purchases and managing licenses

# Stripe webhook signing secret (from Stripe Dashboard → Webhooks)
# STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Stripe product IDs for each tier (from Stripe Dashboard → Products)
# STRIPE_PRODUCT_SELF_HOSTED=prod_your_self_hosted_id
# STRIPE_PRODUCT_CLOUD=prod_your_cloud_id
